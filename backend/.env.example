# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=grouping_master

# 应用密钥（用于 session 签名）
SECRET_KEY=your-secret-key-change-in-production

# 邮件配置（用于找回密码）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@grouping-master.com
SMTP_USE_SSL=false
# 设为 false 可跳过 STARTTLS（如 Mailpit 等本地工具）
SMTP_STARTTLS=true

# 上传目录
UPLOAD_DIR=uploads

# 前端地址（用于 CORS 和重置密码链接）
FRONTEND_URL=http://localhost:5173

# 注册时是否必须设置密码（调试用，默认 true）
REQUIRE_PASSWORD=true

# 数据库连接池（可选）
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# 调试：在 stderr 打印重置密码链接（生产环境勿开启）
# DEV_PRINT_RESET_LINK=true

# CORS：逗号分隔的额外允许域名（生产环境可用此替代正则）
# CORS_ORIGINS=http://your-frontend.com

# Cookie：HTTPS 环境设为 true 开启 Secure 标志
# COOKIE_SECURE=true
