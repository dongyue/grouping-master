# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=grouping_master

# 应用密钥（用于 session 签名）
SECRET_KEY=your-secret-key-change-in-production

# 邮件配置（用于找回密码）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@grouping-master.com
SMTP_USE_SSL=false
# 设为 false 可跳过 STARTTLS（如 Mailpit 等本地工具）
SMTP_STARTTLS=true

# 上传目录
UPLOAD_DIR=uploads

# 前端地址（用于 CORS 和重置密码链接）
FRONTEND_URL=http://localhost:5173

# 注册时是否必须设置密码（调试用，默认 true）
REQUIRE_PASSWORD=true
